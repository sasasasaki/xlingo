{
  "manifest_version": 3,
  "name": "xLingo — CN/JA/EN 三语发信助手",
  "version": "0.3.1",
  "description": "X 输入框中文→日英翻译;任意网页划词→补齐另外两种语言(DeepSeek/Grok/Gemini 自动调配+自有语料库)",
  "permissions": ["storage", "activeTab", "contextMenus"],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://api.x.ai/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": { "service_worker": "bg.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "options_page": "options.html",
  "action": { "default_title": "xLingo 設定(右クリック→オプション)" },
  "commands": {
    "translate": {
      "suggested_key": { "default": "Alt+T" },
      "description": "翻译:X输入框(compose)或当前选中文本(selection)"
    }
  }
}
